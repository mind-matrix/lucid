{
  "name": "@mind-matrix/lucid-components",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": ["./src/**/*.ts", "./dist/**/*.js"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.css",
    "!src/**/test/**"
  ],
  "dependencies": {
    "@mind-matrix/lucid-core": "workspace:*"
  }
}
